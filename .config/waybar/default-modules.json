    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },

  "network": {
    "format-wifi": "<big>ˇ░ĺó</big> {essid}",
    "format-alt": "<big>ˇ░ĺó</big> {bandwidthTotalBits}",
    "format-ethernet": "<big>ˇ░łÇ</big> wired",
    "format-disconnected": "",
    "tooltip-format": "{essid} {signalStrength}%",
    "tooltip-format-disconnected": "Disconnected",
