  "niri/workspaces": {
    "current-only": false,
    "format": "{icon}[{index}]",
    "format-icons": {
      "1": "´äî",
      "2": "´äî",
      "3": "´äî",
      "4": "´äî",
      "5": "´äî",
      "6": "´äî",
      "7": "´äî",
      "8": "´äî",
      "9": "´äî",
      "urgent": "´ü¬",
      "active": "´ćĺ",
      "default": "´äĹ"
    }
  },

  "wireplumber": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
    "format-bluetooth-muted": "ţČĄ {icon}´Őö {format_source}",
    "format-muted": "ţČĄ",
    "format-icons": {
      "headphone": "´Çą",
      "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
    },
    "on-click": "helvum",
